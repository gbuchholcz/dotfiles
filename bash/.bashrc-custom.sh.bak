#Bash shell prompt setup

BLUE_BG='\[\033[48;5;33m\]' # Blue background
GRAY_BG='\[\033[48;5;240m\]' # Gray background
GREEN_BG='\[\033[48;5;2m\]'
WHITE_FG='\[\033[38;5;15m\]' # White text
BLUE_FG='\[\033[38;5;33m\]' # Blue text
GRAY_FG='\[\033[38;5;240m\]' # Gray text
LIGHTGRAY_FG='\[\033[38;5;255m\]' #Light gray text
GREEN_FG='\[\033[38;5;2m\]'
RED_FG='\[\033[38;5;1m\]' #Red text
RESET='\[\033[0m\]'              # Reset all styles
SEP=""                          # Triangle separator (requires Nerd Font)

function _git_prompt {
    printf "${RESET}${GRAY_FG}${SEP}${RESET} " 
    return 0
    local branch=$(git branch 2>/dev/null | grep '^*' | colrm 1 2)
    local git_info=""
    if [ "$branch" ]; then
        # Check for uncommitted changes
        if ! git diff --quiet 2>/dev/null; then
            status="*"
        fi
        # Check for untracked files
        if [ -n "$(git ls-files --others --exclude-standard 2>/dev/null)" ]; then
            status="${status}+"
        fi
        # Check for staged changes
        if ! git diff --cached --quiet 2>/dev/null; then
            status="${status}^"
        fi
        git_info="${branch}${status}"
    fi
    if [[ -n "${git_info}" ]]; then
        echo -n "${GRAY_FG}${GREEN_BG}${WHITE_FG} ${git_info} ${RESET}${GREEN_FG}${SEP}${RESET} "       
    else
        echo -n "${RESET}${GRAY_FG}${SEP}${RESET} "
    fi 
}

